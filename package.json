{
  "name": "electronic-mssql",
  "version": "1.0.3",
  "description": "MSSQL schema browser and DDL exporter",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "electron-vite build && electron-builder",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "mssql": "^11.0.1"
  },
  "build": {
    "appId": "com.electronicmssql",
    "productName": "ElectronicMSSQL",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "!node_modules"
    ],
    "extraResources": [
      {
        "from": "appsettings.json",
        "to": "appsettings.json"
      }
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "esbuild", "electron-builder"]
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "electron-builder": "^25.1.8",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/mssql": "^9.1.5",
    "@types/node": "^20.17.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
